{
  "Hosting": {
    "Urls": [ "http://127.0.0.1:12345" ]
  },
  "SerialRequests": {
    "TargetPaths": [
      "/v1/chat/completions",
      "/v1/responses",
      "/v1/completions",
      "/v1/embeddings",
      "/v1/messages"
    ],
    "Concurrency": 1
  },
  "ReverseProxy": {
    "Routes": {
      "all_route": {
        "ClusterId": "cluster1",
        "Match": {
          "Path": "/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "cluster1": {
        "Destinations": {
          "destination1": {
            "Address": "http://127.0.0.1:23456/"
          }
        }
      }
    }
  }
}